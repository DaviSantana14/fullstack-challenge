{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "docker:up": "docker compose up --build",
    "docker:e2e": "docker compose -f docker-compose.yml -f docker-compose.e2e.yml up --build",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f"
  },
  "devDependencies": {
    "@types/socket.io-client": "^3.0.0",
    "bun-types": "latest"
  },
  "dependencies": {
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/websockets": "^11.1.19",
    "@tanstack/react-query": "^5.100.9",
    "framer-motion": "^12.38.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "zustand": "^5.0.13"
  }
}
